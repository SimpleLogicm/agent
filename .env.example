# AI Agent SDK Configuration
# Run: python setup.py  (fills this automatically)

# License (get from platform dashboard)
PLATFORM_URL=https://agent-web-cdrs.onrender.com
PROJECT_KEY=pk_your_project_key
API_KEY=ak_your_api_key

# Gemini AI (get FREE key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_key
GEMINI_MODEL=gemini-1.5-flash

# Database (auto-connect on startup)
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db
DB_USER=postgres
DB_PASSWORD=your_password

# Agent Server
AGENT_PORT=8000

# Safety
READ_ONLY_MODE=false
MAX_RESULT_ROWS=100
BLOCKED_TABLES=
