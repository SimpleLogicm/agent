# AI Agent SDK Configuration
# Run: python3 setup.py  (to fill this automatically)

# License (get from platform dashboard)
PLATFORM_URL=https://agent-web-cdrs.onrender.com
PROJECT_KEY=pk_your_project_key
API_KEY=ak_your_api_key

# AI Model
OLLAMA_MODEL=llama3.2:3b
OLLAMA_FALLBACK_MODEL=mistral

# Agent Server
AGENT_PORT=8000

# Safety
READ_ONLY_MODE=false
MAX_RESULT_ROWS=100
BLOCKED_TABLES=
